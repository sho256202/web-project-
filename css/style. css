/* التنسيقات العامة وضبط الهوامش */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: #ffffff;
    color: #333333;
    line-height: 1.6;
}

/* تنسيق شريط التنقل العلوي (Header) */
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 8%;
    background-color: #ffffff;
    border-bottom: 1px solid #f5eaed;
    position: sticky;
    top: 0;
    z-index: 1000;
}

.logo {
    font-size: 24px;
    font-weight: 700;
    color: #a94b68;
}

nav a {
    text-decoration: none;
    color: #555555;
    margin: 0 15px;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.3s ease;
}

nav a:hover, nav a.active {
    color: #a94b68;
}

/* تنسيق أزرار اتخاذ الإجراء (Buttons) */
.btn-nav, .btn-main, .btn-small {
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: all 0.3s ease;
    cursor: pointer;
}

.btn-nav {
    background-color: #a94b68;
    color: #ffffff;
    padding: 10px 25px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
}

.btn-nav:hover {
    background-color: #8c3b54;
}

/* تنسيق القسم الترحيبي (Hero Section) */
.hero {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 60px 8%;
    background-color: #faf6f7;
}

.hero-content {
    max-width: 50%;
}

.hero-content h1 {
    font-size: 42px;
    color: #222222;
    margin-bottom: 20px;
    line-height: 1.2;
}

.hero-content p {
    font-size: 16px;
    color: #666666;
    margin-bottom: 30px;
}

.btn-main {
    background-color: #a94b68;
    color: #ffffff;
    padding: 14px 35px;
    border-radius: 25px;
    font-size: 15px;
    font-weight: 600;
}

.btn-main:hover {
    background-color: #8c3b54;
    transform: translateY(-2px);
}

.hero-image {
    max-width: 45%;
}

.hero-image img {
    width: 100%;
    height: auto;
    border-radius: 15px;
}

/* تنسيق قسم التصنيفات الأساسية (Categories Layout) */
.categories {
    display: flex;
    justify-content: space-between;
    padding: 60px 8%;
    background-color: #ffffff;
    gap: 30px;
}

.card {
    flex: 1;
    background-color: #ffffff;
    border: 1px solid #f5eaed;
    border-radius: 15px;
    padding: 25px;
    text-align: center;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.02);
    transition: transform 0.3s ease;
}

.card:hover {
    transform: translateY(-5px);
}

.card img {
    width: 100%;
    max-height: 200px;
    object-fit: contain;
    margin-bottom: 20px;
}

.card h3 {
    font-size: 20px;
    color: #222222;
    margin-bottom: 10px;
}

.card p {
    font-size: 14px;
    color: #666666;
    margin-bottom: 20px;
}

.btn-small {
    background-color: #ffffff;
    color: #a94b68;
    border: 1px solid #a94b68;
    padding: 8px 20px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
}

.btn-small:hover {
    background-color: #a94b68;
    color: #ffffff;
}

/* تنسيق شبكة المجموعات الجديدة (CSS Grid Layout) */
.collections {
    padding: 60px 8%;
    background-color: #faf6f7;
}

.section-title {
    text-align: center;
    font-size: 32px;
    color: #222222;
    margin-bottom: 40px;
}

.grid-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
}

.grid-item {
    background-color: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #f5eaed;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.01);
    display: flex;
    flex-direction: column;
}

.grid-item img {
    width: 100%;
    height: 180px;
    object-fit: contain;
    background-color: #ffffff;
    padding: 15px;
}

.item-info {
    padding: 20px;
    text-align: center;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    justify-content: space-between;
}

.grid-item h4 {
    font-size: 18px;
    color: #222222;
    margin-bottom: 8px;
}

.grid-item p {
    font-size: 13px;
    color: #777777;
    margin-bottom: 15px;
}

/* تنسيق تذييل الصفحة وبطاقة التعريف (Footer & Developer Card) */
footer {
    background-color: #ffffff;
    border-top: 1px solid #f5eaed;
    padding: 60px 8% 20px 8%;
}

.footer-container {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    margin-bottom: 40px;
}

.footer-column {
    flex: 1;
}

.brand-info h3 {
    font-size: 24px;
    color: #a94b68;
    margin-bottom: 15px;
}

.brand-info p {
    font-size: 14px;
    color: #666666;
    max-width: 350px;
}

.developer-card {
    background-color: #faf6f7;
    padding: 25px;
    border-radius: 12px;
    border: 1px solid #f5eaed;
}

.developer-card h4 {
    font-size: 14px;
    color: #a94b68;
    text-transform: uppercase;
    margin-bottom: 10px;
    letter-spacing: 1px;
}

.developer-card h5 {
    font-size: 18px;
    color: #222222;
    margin-bottom: 5px;
}

.badge {
    display: inline-block;
    background-color: #e8cfd6;
    color: #a94b68;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 10px;
    margin-bottom: 12px;
}

.dev-quote {
    font-size: 13px;
    font-style: italic;
    color: #555555;
    margin-bottom: 15px;
}

.dev-contact p {
    font-size: 13px;
    color: #666666;
    margin-bottom: 15px;
}

.dev-contact i {
    color: #a94b68;
    margin-right: 8px;
}

.social-icons a {
    color: #a94b68;
    font-size: 16px;
    margin-right: 15px;
    transition: color 0.3s ease;
}

.social-icons a:hover {
    color: #8c3b54;
}

.footer-bottom {
    text-align: center;
    border-top: 1px solid #f5eaed;
    padding-top: 20px;
    font-size: 13px;
    color: #888888;
}

.dev-signature {
    text-decoration: none;
    color: #a94b68;
    font-weight: 600;
}

/* شاشات الهواتف والأجهزة اللوحية المتجاوبة (Responsive Queries) */
@media (max-width: 992px) {
    .grid-container {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    header {
        flex-direction: column;
        gap: 15px;
        padding: 15px;
    }
    
    .hero {
        flex-direction: column;
        text-align: center;
        padding: 40px 20px;
    }
    
    .hero-content {
        max-width: 100%;
        margin-bottom: 30px;
    }
    
    .hero-image {
        max-width: 100%;
    }
    
    .categories {
        flex-direction: column;
        padding: 40px 20px;
    }
    
    .grid-container {
        grid-template-columns: 1fr;
    }
    
    .footer-container {
        flex-direction: column;
        gap: 30px;
    }
}
